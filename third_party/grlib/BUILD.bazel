exports_files([
    "grlib.BUILD",
])

genrule(
    name = "stdio_2008",
    srcs = ["@grlib_srcs//:lib/grlib/stdlib/stdio.vhd"],
    outs = ["lib/grlib/stdlib/stdio_2008.vhd"],
    cmd = "python3 $(location patch_vhdl_2008.py) stdio $< $@",
    tools = ["patch_vhdl_2008.py"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "testlib_2008",
    srcs = ["@grlib_srcs//:lib/grlib/stdlib/testlib.vhd"],
    outs = ["lib/grlib/stdlib/testlib_2008.vhd"],
    cmd = "python3 $(location patch_vhdl_2008.py) testlib $< $@",
    tools = ["patch_vhdl_2008.py"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "kconfig_all",
    srcs = glob(["kconfig/**/*.Kconfig"]),
    visibility = ["//visibility:public"],
)

genrule(
    name = "gen_config_vhd",
    srcs = ["config_h"],
    outs = ["config.vhd"],
    cmd = "PREFIX=$$(grep '^#define CONFIG_ACTIVE_DESIGN_PREFIX' $< | awk '{print $$3}' | tr -d '\"' | tr -d '\\r' || true); " +
          "$(location //third_party/grlib/scripts:gen_config_vhd) --prefix \"$$PREFIX\" $< $@",
    tools = ["//third_party/grlib/scripts:gen_config_vhd"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "config_vhd_file",
    srcs = ["config.vhd"],
    visibility = ["//visibility:public"],
)

alias(
    name = "config_h",
    actual = "@grlib_config//:config_h",
    visibility = ["//visibility:public"],
)
