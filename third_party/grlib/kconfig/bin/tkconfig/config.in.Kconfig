config PERI_LCONF
    bool
    default y

mainmenu "LEON Processor Configuration"

menu "Options"
comment "Synthesis "
# choice translation skipped
	"Generic		CONFIG_SYN_GENERIC \
	Atmel-ATC35		CONFIG_SYN_ATC35 \
	Atmel-ATC25		CONFIG_SYN_ATC25 \
	Atmel-ATC18		CONFIG_SYN_ATC18 \
	UMC-FS90 		CONFIG_SYN_FS90 \
	UMC-0.18 		CONFIG_SYN_UMC018 \
	TSMC-0.25		CONFIG_SYN_TSMC025 \
	Actel-Proasic		CONFIG_SYN_PROASIC \
	Actel-Axcel  		CONFIG_SYN_AXCEL \
	Xilinx-Virtex		CONFIG_SYN_VIRTEX \
	Xilinx-Virtex2		CONFIG_SYN_VIRTEX2" Generic
if y # TODO: improve if translation
config SYN_INFER_RAM
    bool "Infer cache and trace buffer RAM"
config SYN_INFER_REGF
    bool "Infer register file"
if y # TODO: improve if translation
config SYN_INFER_ROM
    bool "Infer ROM"
endif
    if [ "$CONFIG_SYN_VIRTEX" != "y" -a "$CONFIG_SYN_AXCEL" != "y" \
         -a "$CONFIG_SYN_VIRTEX2" != "y" -a "$CONFIG_SYN_PROASIC" != "y" ]; then
config SYN_INFER_PADS
    bool "Infer pads"
endif
if y # TODO: improve if translation
config SYN_INFER_PCI_PADS
    bool "Infer PCI pads"
endif
endif
config SYN_INFER_MULT
    bool "Infer multiplier"
  if [ "$CONFIG_SYN_GENERIC" = "y" -o "$CONFIG_SYN_VIRTEX" = "y" \
     -o "$CONFIG_SYN_AXCEL" = "y" -o "$CONFIG_SYN_ATC25" = "y" \
     -o "$CONFIG_SYN_INFER_REGF" = "y" -o "$CONFIG_SYN_VIRTEX2" = "y"]; then
config SYN_RFTYPE
    bool "Improve register file write timing"
endif
  if [ "$CONFIG_SYN_ATC25" = "y" -o "$CONFIG_SYN_VIRTEX" = "y" -o "$CONFIG_SYN_VIRTEX2" = "y"\
       -o "$CONFIG_SYN_ATC18" = "y" -o "$CONFIG_SYN_TSMC025" = "y" ]; then
if y # TODO: improve if translation
      bool 'Use dual-port RAM for DSU trace buffer   ' \
	CONFIG_SYN_TRACE_DPRAM $CONFIG_SYN_ATC25 $CONFIG_SYN_ATC18 \
	$CONFIG_SYN_VIRTEX $CONFIG_SYN_TSMC025 $CONFIG_SYN_VIRTEX2
endif
endif
endmenu

menu "Options"
comment "Clock generation"
if y # TODO: improve if translation
config CLK_VIRTEX
    bool "Use Virtex CLKDLL for clock generation"
endif
if y # TODO: improve if translation
config CLK_VIRTEX2
    bool "Use Virtex-II DCM for clock generation"
endif
if y # TODO: improve if translation
# choice translation skipped
	"1/2		CONFIG_CLKDLL_1_2 \
	1		CONFIG_CLKDLL_1_1 \
	2		CONFIG_CLKDLL_2_1" 1
endif
if y # TODO: improve if translation
# choice translation skipped
	"2/3		CONFIG_DCM_2_3 \
	3/4		CONFIG_DCM_3_4 \
	4/5		CONFIG_DCM_4_5 \
	1		CONFIG_DCM_1_1 \
	5/4		CONFIG_DCM_5_4 \
	4/3		CONFIG_DCM_4_3 \
	3/2		CONFIG_DCM_3_2 \
	5/3		CONFIG_DCM_5_3 \
	2		CONFIG_DCM_2_1 \
	3		CONFIG_DCM_3_1 \
	4		CONFIG_DCM_4_1" 1
endif
if y # TODO: improve if translation
config AXCEL_HCLKBUF
    bool "Use global clock pad (Actel AX)"
endif
if y # TODO: improve if translation
config PCI_DLL
    bool "Enable CLKDLL for PCI clock"
endif
if y # TODO: improve if translation
config PCI_SYSCLK
    bool "Use PCI clock as system clock"
endif
endmenu

menu "Options"
comment "Processor            "
menu "Options"
comment "Integer unit                                           "
config IU_NWINDOWS
    int "SPARC register windows"
    default 8
config IU_V8MULDIV
    bool "SPARC V8 MUL/DIV instructions"
if y # TODO: improve if translation
# choice translation skipped
	"1-cycle		CONFIG_IU_MUL_LATENCY_1 \
	2-cycles		CONFIG_IU_MUL_LATENCY_2 \
	4-cycles		CONFIG_IU_MUL_LATENCY_4 \
	5-cycles		CONFIG_IU_MUL_LATENCY_5 \
	35-cycles		CONFIG_IU_MUL_LATENCY_35" 5-cycles
endif
  dep_bool 'SPARC V8e SMAC/UMAC instructions     ' CONFIG_IU_MUL_MAC $CONFIG_IU_MUL_LATENCY_4 $CONFIG_IU_V8MULDIV
config IU_LDELAY
    int "Load delay"
    default 1
config IU_FASTJUMP
    bool "Fast jump-address generation   "
config IU_ICCHOLD
    bool "ICC interlock                  "
config IU_FASTDECODE
    bool "Fast instruction decoding      "
  if [ "$CONFIG_SYN_TSMC025" = "y" -o "$CONFIG_SYN_UMC018" = "y" \
    -o "$CONFIG_SYN_FS90" = "y" -o "$CONFIG_SYN_PROASIC" = "y" \
    -o "$CONFIG_SYN_ATC18" = "y" \
    -o "$CONFIG_SYN_AXCEL" = "y" -o "$CONFIG_SYN_ATC25" = "y" ]; then
config IU_RFPOW
    bool "Register file power-saving     "
endif
config IU_WATCHPOINTS
    int "Hardware watchpoints"
    default 0
endmenu
menu "Options"
comment "Floating-point unit"
config FPU_ENABLE
    bool "Enable FPU                             "
if y # TODO: improve if translation
# choice translation skipped
	"GRFPU		CONFIG_FPU_GRFPU \
	Meiko		CONFIG_FPU_MEIKO \
	LTH		CONFIG_FPU_LTH" GRFPU
config FPU_VER
    int "FSR version ID"
    default 0
endif
endmenu
menu "Options"
comment "Co-processor"
config CP_ENABLE
    bool "Enable co-processor       "
if y # TODO: improve if translation
    string 'Co-processor configuration' CONFIG_CP_CFG "cp_none"
endif
endmenu
menu "Options"
comment "Cache system              "
comment "Instruction cache                              "
# choice translation skipped
	"1		CONFIG_ICACHE_ASSO1 \
	2		CONFIG_ICACHE_ASSO2 \
	3		CONFIG_ICACHE_ASSO3 \
	4		CONFIG_ICACHE_ASSO4" 1
# choice translation skipped
	"1		CONFIG_ICACHE_SZ1 \
	2		CONFIG_ICACHE_SZ2 \
	4		CONFIG_ICACHE_SZ4 \
	8		CONFIG_ICACHE_SZ8 \
	16		CONFIG_ICACHE_SZ16 \
	32		CONFIG_ICACHE_SZ32 \
	64		CONFIG_ICACHE_SZ64" 2
