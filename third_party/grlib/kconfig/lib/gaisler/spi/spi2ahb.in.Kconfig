config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB
    bool "Enable SPI to AHB bridge "
#    if [ "$CONFIG_SPI2AHB" = "y" ]; then
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_APB
    bool "Enable APB interface   "
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_ADDRH
    hex "AHB protection address (high) "
    default 0000
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_ADDRL
    hex "AHB protection address (low) "
    default 0000
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_MASKH
    hex "AHB protection mask (high) "
    default 0000
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_MASKL
    hex "AHB protection mask (low) "
    default 0000
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_RESEN
    bool "Enable after reset  "
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_CPOL
    hex "Clock polarity "
    default 0
config LIB_GAISLER_SPI_SPI2AHB_SPI2AHB_CPHA
    hex "Clock phase    "
    default 0
