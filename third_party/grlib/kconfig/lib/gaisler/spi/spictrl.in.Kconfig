config LIB_GAISLER_SPI_SPICTRL_SPICTRL_ENABLE
    bool "Enable SPI controller(s) "
#     if [ "$CONFIG_SPICTRL_ENABLE" = "y" ]; then
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_NUM
    int "Number of SPI controllers   "
    default 1
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_SLVS
    int "Slave select lines    "
    default 1
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_FIFO
    int "FIFO depth (2^N)      "
    default 1
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_SLVREG
    bool "Enable slave select registers"
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_ASEL
    bool "Enable automatic slave select"
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_AM
    bool "Support automated transfers  "
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_ODMODE
    bool "Support open drain mode      "
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_TWEN
    bool "Support three-wire protocol  "
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_MAXWLEN
    int "Maximum supported word length (see help!) "
    default 0
config LIB_GAISLER_SPI_SPICTRL_SPICTRL_SYNCRAM
    bool "Use SYNCRAM for rx and tx queues "
