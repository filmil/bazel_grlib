#   mainmenu_option next_comment
#   comment 'SPI memory controller '
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL
    bool "Enable SPI memory controller    "
#     if [ "$CONFIG_SPIMCTRL" = "y" ]; then
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_READCMD
    hex "Read instruction    "
    default 0B
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_DUMMYBYTE
    bool "Read instruction requires dummy byte  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_DUALOUTPUT
    bool "Enable dual output  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_QUADOUTPUT
    bool "Enable quad output  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_DUALINPUT
    bool "Enable dual input  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_QUADINPUT
    bool "Enable quad input  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_DSPI
    bool "Enable DSPI mode  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_QSPI
    bool "Enable QSPI mode  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_DUMMYCYCLES
    int "Number of dummy cycles  "
    default 0
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_EXTADDR
    bool "Use 4 byte address instead of 3  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_OFFSET
    hex "Address offset     "
    default 0
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_SCALER
    int "Clock divisor for device clock"
    default 1
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_ASCALER
    int "Clock divisor for alt. device clock"
    default 8
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_RECONF
    bool "Enables writes for configuration register  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_WRITECMD
    hex "Write instruction    "
    default 02
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_WRITES
    bool "Allow ROM area writes  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_XIPBYTE
    bool "Send XIP byte  "
config LIB_GAISLER_SPI_SPIMCTRL_SPIMCTRL_XIPPOL
    int "XIP disable bit polarity  "
    default 1
#     fi
#   endmenu
