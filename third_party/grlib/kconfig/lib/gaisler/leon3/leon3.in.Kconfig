    bool "SPARC V8 MUL/DIV instructions"
if y # TODO: improve if translation
# choice translation skipped
	  "2-cycles		CONFIG_IU_MUL_LATENCY_2 \
	  4-cycles		CONFIG_IU_MUL_LATENCY_4 \
	  5-cycles		CONFIG_IU_MUL_LATENCY_5" 5-cycles
if y # TODO: improve if translation
config IU_MUL_MAC
    bool "SPARC V8e SMAC/UMAC instructions     "
endif
# choice translation skipped
	  "Inferred		CONFIG_IU_MUL_INFERRED \
	  NTNU_Modgen		CONFIG_IU_MUL_MODGEN \
	  TechSpec		CONFIG_IU_MUL_TECHSPEC \
	  Designware		CONFIG_IU_MUL_DW" Inferred
endif
config IU_BP
    bool "Branch prediction     "
config IU_SVT
    bool "Single-vector trapping"
config IU_LDELAY
    int "Load delay"
    default 1
config IU_WATCHPOINTS
    int "Hardware watchpoints"
    default 0
config PWD
    bool "Enable power-down mode "
config IU_RSTADDR
    hex " Reset start address (addr[31:12]) "
    default 00000
config NP_ASI
    bool "SPARC V8E non-privileged ASI access"
config WRPSR
    bool "SPARC V8E partial Write %psr (WRPSR)"
config ALTWIN
    bool "SPARC V8E AWP and regfile partitioning "
config REX
    bool "Enable LEON-REX extension"
endmenu
