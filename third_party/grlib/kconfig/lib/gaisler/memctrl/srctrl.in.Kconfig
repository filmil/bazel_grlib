    bool "8-bit PROM interface "
config SRCTRL_PROMWS
    int "PROM waitstates"
    default 3
config SRCTRL_RAMWS
    int "RAM waitstates"
    default 0
config SRCTRL_IOWS
    int "IO waitstates"
    default 0
config SRCTRL_RMW
    bool "Use read-modify-write for sub-word writes  "
