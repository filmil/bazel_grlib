config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_ENABLE
    bool "NANDFCTRL - NAND Flash Memory Controller"
# if [ "$CONFIG_NANDFCTRL_ENABLE" = "y" ]; then
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_NTARGETS
    int "Number of targets (1-4)"
    default 2
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_NLANES
    int "Number of lanes (1-8)"
    default 8
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_PSIZE
    int "Page buffer size (bytes)"
    default 4096
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_SSIZE
    int "Spare page buffer size (bytes)"
    default 256
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_TM1
    bool "Enable timing mode 1"
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_TM2
    bool "Enable timing mode 2"
config LIB_GAISLER_NAND_NANDFCTRL_NANDFCTRL_TM3
    bool "Enable timing mode 3"
# fi
