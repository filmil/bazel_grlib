config GRPCI2_VENDORID
    hex "PCI vendor ID"
    default 1AC8
config GRPCI2_DEVICEID
    hex "PCI device ID"
    default 0054
config GRPCI2_CLASS
    hex "PCI class code"
    default 000000
config GRPCI2_REVID
    hex "PCI Revision ID"
    default 00
config GRPCI2_CAPPOINT
    hex "Capability pointer"
    default 40
config GRPCI2_NEXTCAPPOINT
    hex "Next Capability pointer"
    default 00
