config LIB_GAISLER_MISC_GPTIMER_GPT_ENABLE
    bool "Enable Timer Unit                    "
#     if [ "$CONFIG_GPT_ENABLE" = "y" ]; then
config LIB_GAISLER_MISC_GPTIMER_GPT_NTIM
    int "Number of timers (1 - 7)              "
    default 2
config LIB_GAISLER_MISC_GPTIMER_GPT_SW
    int "Scaler width (2 - 16)                 "
    default 8
config LIB_GAISLER_MISC_GPTIMER_GPT_TW
    int "Timer width (2 - 32)                  "
    default 32
config LIB_GAISLER_MISC_GPTIMER_GPT_IRQ
    int "Timer unit interrupt                  "
    default 8
config LIB_GAISLER_MISC_GPTIMER_GPT_SEPIRQ
    bool "Separate interrupts                  "
config LIB_GAISLER_MISC_GPTIMER_GPT_WDOGEN
    bool "Watchdog enable                      "
#       if [ "$CONFIG_GPT_WDOGEN" = "y" ]; then
config LIB_GAISLER_MISC_GPTIMER_GPT_WDOG
    hex "Initial watchdog time-out value       "
    default FFFF
#       fi
#     fi
