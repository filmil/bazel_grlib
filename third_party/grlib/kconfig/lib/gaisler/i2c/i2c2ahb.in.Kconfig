config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB
    bool "Enable I2C to AHB bridge "
#    if [ "$CONFIG_I2C2AHB" = "y" ]; then
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_APB
    bool "Enable APB interface   "
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_ADDRH
    hex "AHB protection address (high) "
    default 0000
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_ADDRL
    hex "AHB protection address (low) "
    default 0000
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_MASKH
    hex "AHB protection mask (high) "
    default 0000
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_MASKL
    hex "AHB protection mask (low) "
    default 0000
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_RESEN
    bool "Enable after reset  "
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_SADDR
    hex "I2C memory address "
    default 50
config LIB_GAISLER_I2C_I2C2AHB_I2C2AHB_CADDR
    hex "I2C configuration address "
    default 51
#    fi
