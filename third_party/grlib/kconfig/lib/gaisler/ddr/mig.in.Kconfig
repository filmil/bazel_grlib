    int "Column bits  "
    default 10
config MIG_ROWBITS
    int "Row bits     "
    default 13
config MIG_BANKBITS
    int "Bank bits    "
    default 2
config MIG_HMASK
    hex "AHB HMASK    "
    default F00
endif
endmenu
