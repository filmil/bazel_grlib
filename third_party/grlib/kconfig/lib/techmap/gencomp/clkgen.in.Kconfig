config LIB_TECHMAP_GENCOMP_CLKGEN_CLK_MUL
    int "Clock multiplication factor (2 - 32)"
    default 2
config LIB_TECHMAP_GENCOMP_CLKGEN_CLK_DIV
    int "Clock division factor (2 - 32)"
    default 2
