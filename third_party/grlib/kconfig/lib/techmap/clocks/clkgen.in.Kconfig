config CLK_MUL
    int "Clock multiplication factor (allowed values are tech dependent)"
    default 2
#       if [ "$CONFIG_CLK_BRAVEMED" != "y" ]; then 
config CLK_DIV
    int "Clock division factor (allowed values are tech dependent)"
    default 2
#       fi
#     fi
#     if [ "$CONFIG_CLK_PRO3PLL" = "y" -o "$CONFIG_CLK_PRO3EPLL" = "y" \
#          -o "$CONFIG_CLK_PRO3LPLL" = "y" -o "$CONFIG_CLK_FUSPLL" = "y" \
# 	 -o "$CONFIG_CLK_BRAVEMED" = "y"]; then
config OCLK_DIV
    int "Outout division factor (0 - 32, see help)"
    default 1
config OCLKB_DIV
    int "Outout division factor, 2nd clk (0 - 32, see help)"
    default 0
config OCLKC_DIV
    int "Outout division factor, 3rd clk (0 - 32, see help)"
    default 0
#     fi
#     if [ "$CONFIG_CLK_CLKDLL" = "y" -o "$CONFIG_CLK_DCM" = "y" ]; then
config PCI_CLKDLL
    bool "Enable Xilinx CLKDLL for PCI clock"
#     fi
#     if [ "$CONFIG_CLK_DCM" = "y" ]; then
config CLK_NOFB
    bool "Disable external feedback for SDRAM clock"
#     fi
#   if [ "$CONFIG_PCI_ENABLE" != "y" ]; then
config PCI_SYSCLK
    bool "Use PCI clock as system clock"
#   fi
