load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "scripts_lib",
    srcs = ["gen_build_files.go"],
    importpath = "grlib/third_party/grlib/scripts",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "gen_build_files",
    embed = [":scripts_lib"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "in2kconfig_lib",
    srcs = ["in2kconfig.go"],
    importpath = "grlib/third_party/grlib/scripts/in2kconfig",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "in2kconfig",
    embed = [":in2kconfig_lib"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "gen_config_vhd_lib",
    srcs = ["gen_config_vhd.go"],
    importpath = "grlib/third_party/grlib/scripts/gen_config_vhd",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "gen_config_vhd",
    embed = [":gen_config_vhd_lib"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "gen_master_kconfig_lib",
    srcs = ["gen_master_kconfig.go"],
    importpath = "grlib/third_party/grlib/scripts/gen_master_kconfig",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "gen_master_kconfig",
    embed = [":gen_master_kconfig_lib"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "gen_example_bazelrc_lib",
    srcs = ["gen_example_bazelrc.go"],
    importpath = "grlib/third_party/grlib/scripts/gen_example_bazelrc",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "gen_example_bazelrc",
    embed = [":gen_example_bazelrc_lib"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "maintain_lib",
    srcs = ["maintain.go"],
    importpath = "grlib/third_party/grlib/scripts/maintain",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "maintain",
    data = [
        ":gen_build_files",
        ":gen_config_vhd",
        ":gen_example_bazelrc",
        ":in2kconfig",
        "@grlib_srcs//:grlib_srcs_all",
    ],
    embed = [":maintain_lib"],
    visibility = ["//visibility:public"],
)
