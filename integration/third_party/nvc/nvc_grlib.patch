+   if (nparams != 1)
+      return t;
+
+   tree_t index_expr = tree_value(tree_param(t, 0));
+   int64_t index_val;
+   if (!simp_eval_int(index_expr, ctx, &index_val))
+      return t;
+
+   type_t type = tree_type(prefix);
+   tree_t r = range_of(type, 0);
+   int64_t left, right;
+   if (!folded_bounds(r, &left, &right))
