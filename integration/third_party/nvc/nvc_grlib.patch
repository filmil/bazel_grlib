+   const int nassocs = tree_assocs(t);
+   for (int i = 0; i < nassocs; i++) {
+      tree_t assoc = tree_assoc(t, i);
+      if (!simp_is_const_scalar(tree_value(assoc)))
+         return false;
+   }
+   return true;
+}
